#!/usr/bin/env ruby
# frozen_string_literal: true

require "optparse"
require_relative "../lib/codeowners_validator"

OptionParser.new do |opts|
  opts.banner = "Usage: #{$PROGRAM_NAME} [CODEOWNERS_PATH]"
end.parse!(ARGV)

codeowners_path = ARGV.shift || File.expand_path("../../CODEOWNERS", __dir__)

unless File.file?(codeowners_path)
  puts "CODEOWNERS file not found at #{codeowners_path}"
  exit 1
end

CodeownersValidator::SortPatterns.new(codeowners_path).run
